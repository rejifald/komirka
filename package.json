{
  "name": "komirka",
  "version": "0.0.0",
  "description": "Atomic configuration — every config value is an inert, importable, documented, validated descriptor, bound explicitly per runtime. Design phase: this release reserves the name; see the repository for the full design.",
  "keywords": [
    "config",
    "configuration",
    "env",
    "environment",
    "secrets",
    "standard-schema",
    "atomic-config",
    "typescript"
  ],
  "license": "Apache-2.0",
  "author": "Oleksandr Zhuravlov",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rejifald/komirka.git"
  },
  "homepage": "https://github.com/rejifald/komirka#readme",
  "bugs": "https://github.com/rejifald/komirka/issues",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.3",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "//": "Future subpath entries (principles.md P5): ./node, ./workers, ./async, ./testing kit, plus a `komirka` bake CLI bin. Add each to tsup `entry` and this `exports` map when its source lands.",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "size": "size-limit",
    "check:exports": "attw --pack . && publint",
    "prepare": "husky",
    "prepack": "pnpm build"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
